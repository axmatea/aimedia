# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local outreach scripts & state (contain prospect emails)
/scripts/send-alexandra-*.mjs
/scripts/schedule-alexandra-*.mjs
/scripts/cancel-alexandra-*.mjs
/scripts/send-audition-fee.mjs
/scripts/outreach/send-selena-*.mjs
/scripts/outreach/send-gamma-*.mjs
/scripts/outreach/send-sam-*.mjs
/scripts/outreach/preview-naxmatea-*.mjs
/data/

# claude local
.claude/
/scripts/outreach/send-sam-docs.mjs
/scripts/outreach/send-sam-phase1-confirm.mjs
/scripts/outreach/send-sam-final.mjs
/scripts/outreach/send-sam-nudge.mjs

# local audit reports (generated by npm run audit)
/docs/audit/
/.lighthouseci/

# generated-image source PNGs (only the optimized .webp ship)
/public/generated/outcomes/_src/

# local asset archive: files pulled OUT of the deploy payload live here, never
# in public/ (anything in public/ uploads to prod). Keep on disk, not in git.
/_assets-archive/

# working renders that must never ride along in the deploy payload again
/public/chrome-sentinel.png
/public/hybrid-sentinel.png
/public/hero-keyvisual.png
/public/logo-gen/
/public/logo-preview-gen.html
