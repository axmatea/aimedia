# --- Instagram content agent (see docs/instagram-agent.md) ---

# Claude API — content generation, reference analysis, DM replies
ANTHROPIC_API_KEY=

# Meta / Instagram Graph API
IG_USER_ID=                  # Instagram Business account id
IG_ACCESS_TOKEN=             # long-lived token: instagram_content_publish + instagram_manage_messages
IG_VERIFY_TOKEN=             # any random string; must match the webhook setup in Meta dashboard
META_APP_SECRET=             # app secret — verifies webhook signatures
GRAPH_API_VERSION=v23.0

# Telegram — owner's control panel (references, approvals, notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=      # send /start to the bot to discover it
TELEGRAM_WEBHOOK_SECRET=     # pass the same value as secret_token to setWebhook

# Storage — Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron protection
CRON_SECRET=

# Content tuning (optional)
IG_LANGUAGE=ru               # language of generated captions and default DM replies
# IG_BRAND_VOICE=            # override the built-in brand voice prompt
